rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && getUserData().role == 'admin';
    }

    function isTeacherOrAdmin() {
      return isSignedIn() && (getUserData().role == 'teacher' || getUserData().role == 'admin')
             && getUserData().status == 'active';
    }

    // ─── users ───
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      allow update: if isAdmin() || (isOwner(uid) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'status', 'approvedAt', 'approvedBy']));
    }

    // ─── classes ───
    match /classes/{classCode} {
      allow read: if isSignedIn();
      allow create: if isTeacherOrAdmin();
      allow update: if isAdmin() || (isTeacherOrAdmin() && resource.data.teacherId == request.auth.uid);
    }

    // ─── progress ───
    match /progress/{uid} {
      allow read: if isOwner(uid) || isTeacherOrAdmin();
      allow write: if isOwner(uid);
    }
  }
}
